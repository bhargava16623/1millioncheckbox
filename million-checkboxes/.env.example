# Server port
PORT=3000

# This app's public URL
APP_URL=http://localhost:3000

# OIDC Auth Server URL
AUTH_SERVER=http://localhost:8000

# OAuth Client Credentials (from /admin/register on auth server)
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379
